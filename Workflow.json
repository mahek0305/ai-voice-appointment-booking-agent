      "parameters": {
        "jsCode": "const tc = $('Parse Tool Call').item.json;\nconst resultText = `Great, your ${tc.service} appointment is confirmed for ${tc.date} at ${tc.time}. You'll receive a confirmation shortly. Is there anything else I can help with?`;\nreturn [{\n  json: {\n    toolCallId: tc.toolCallId,\n    resultText\n  }\n}];"
      },
